{
  "name": "holdem-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Holdem Poker Game - Monorepo",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @holdem/miniapp dev:weapp",
    "dev:miniapp": "pnpm --filter @holdem/miniapp dev:weapp",
    "build": "pnpm run -r build",
    "build:miniapp": "pnpm --filter @holdem/miniapp build:weapp",
    "typecheck": "pnpm run -r typecheck",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "clean": "pnpm run -r clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/minimatch": "^6.0.0",
    "@types/node": "^24.10.1",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3"
  }
}
